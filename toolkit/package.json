{
  "name": "@n1x-technologies/cortex",
  "version": "0.1.2",
  "description": "Turn any markdown vault into an AI-queryable knowledge graph (CLI + local viewer + cited query + AI atomization).",
  "license": "MIT",
  "type": "module",
  "bin": {
    "cortex": "./dist/cli.js"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "knowledge-graph",
    "markdown",
    "obsidian",
    "cli",
    "rag",
    "notes",
    "zettelkasten"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/n1x-technologies/n1x-cortex.git",
    "directory": "toolkit"
  },
  "homepage": "https://github.com/n1x-technologies/n1x-cortex#readme",
  "bugs": {
    "url": "https://github.com/n1x-technologies/n1x-cortex/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsc && node scripts/copy-static.mjs && node scripts/copy-meta.mjs",
    "prepack": "npm run build",
    "cli": "tsx src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cytoscape": "^3.34.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "peerDependenciesMeta": {
    "@xenova/transformers": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@xenova/transformers": "^2.17.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
